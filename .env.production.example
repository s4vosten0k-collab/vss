# Скопируйте в .env.production.local (рядом с package.json) перед сборкой для хостинга.
# Секреты (ключи к API) в клиент Next.js не попадают, только NEXT_PUBLIC_*.

# Публичный URL сервиса помощника (обязателен для работы вкладки на сайте)
# Актуальный бэкенд: Render — https://vss-vfl5.onrender.com/assistant
NEXT_PUBLIC_ASSISTANT_API_URL=https://vss-vfl5.onrender.com/assistant

# Только если сайт отдаётся не из корня домена, а из подпапки, например /vss/
# NEXT_PUBLIC_BASE_PATH=vss
