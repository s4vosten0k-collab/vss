# Для `next dev` URL из `.env.local` часто ведут на production API (Render) — тогда тестируется СТАРЫЙ бэкенд.
# Создайте `.env.development.local` с NEXT_PUBLIC_ASSISTANT_API_URL=http://127.0.0.1:8787/assistant чтобы ходить на локальный assistant/server.mjs
NEXT_PUBLIC_ASSISTANT_API_URL=http://127.0.0.1:8787/assistant
# Пусто = корень сайта. Для публикации в подпапку (https://домен/vss/): vss
# NEXT_PUBLIC_BASE_PATH=

# Optional for LLM mode via OpenRouter (recommended stronger model)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen3-next-80b-a3b-instruct:free
OPENROUTER_MODEL_FALLBACKS=openai/gpt-oss-120b:free,openai/gpt-oss-20b:free,google/gemma-3-12b-it:free,qwen/qwen3-coder:free,meta-llama/llama-3.3-70b-instruct:free

# Optional assistant server tuning
ASSISTANT_PORT=8787
ASSISTANT_HOST=127.0.0.1
# Render sets PORT automatically. Locally you can use ASSISTANT_PORT.
KNOWLEDGE_BASE_PATH=public/assistant-sources/epbt/epbt-structured.json
MEDICINE_KNOWLEDGE_PATH=public/assistant-sources/medicine/medicine-blocks.json
